# Required for local development and Vercel runtime
# The runtime also accepts Vercel Postgres aliases such as POSTGRES_PRISMA_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/examops?schema=public"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/examops?schema=public"
AUTH_SECRET="replace-with-a-long-random-secret"
# Optional: omit this variable entirely to use the default 12-hour session TTL.
AUTH_SESSION_TTL_HOURS="12"
SEED_APP_USERS_PASSWORD="ChangeMe123!"
