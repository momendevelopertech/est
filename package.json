{
  "name": "examops",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "build:vercel": "prisma generate && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:integration": "node tmp/tests/run-all.mjs",
    "test:integration:assignment": "node tmp/tests/integration/assignment/coverage.mjs",
    "test:integration:notifications": "node tmp/tests/integration/notifications/coverage.mjs",
    "test:integration:reporting": "node tmp/tests/integration/reporting/coverage.mjs",
    "data:import:real-est": "tsx scripts/import_real_est_data.ts",
    "db:migrate": "prisma migrate deploy",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/client": "5.22.0",
    "bcryptjs": "^2.4.3",
    "next": "14.2.35",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.6",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
